
# liubai-runtime 环境变量模板
# 复制为 .env 或在 docker compose 中引用

# MongoDB（独立 db 容器）
MONGODB_URI=mongodb://db:27017/liubai
MONGODB_DB=liubai

# Runtime 服务
RUNTIME_PORT=9000
RUNTIME_HOST=0.0.0.0
APPID=liubai

# 定时任务内部触发 token（对应 x-laf-trigger-token）
LIU_TRIGGER_TOKEN=change-me-in-production

# 设为 01 可禁用容器内 cron
# LIU_DISABLE_CRON=

# --- 以下与 liubai-laf/.env.template 相同 ---

LIU_APP_NAME=Liubai
LIU_CLOUD_ON=01
LIU_CLOUD_LOGIN=01 # 01=开放登录与注册(默认) 02=关闭登录 03=仅登录不注册
LIU_DOMAIN=

LIU_DEBUG_KEY=

LIU_GITHUB_OAUTH_CLIENT_ID=
LIU_GITHUB_OAUTH_CLIENT_SECRET=

LIU_GOOGLE_OAUTH_CLIENT_ID=
LIU_GOOGLE_OAUTH_CLIENT_SECRET=

LIU_RESEND_API_KEY=
LIU_RESEND_FROM_EMAIL=

LIU_STRIPE_API_KEY=
LIU_STRIPE_ENDPOINT_SECRET=
LIU_STRIPE_TEST_PRICE_ID=

LIU_QINIU_ACCESS_KEY=
LIU_QINIU_SECRET_KEY=
LIU_QINIU_BUCKET=
LIU_QINIU_CALLBACK_URL=
LIU_QINIU_CDN_DOMAIN=
LIU_QINIU_CUSTOM_KEY=

LIU_WEB_PUSH_PROXY_HOST=

# ffmpeg 服务（Compose 内网地址）
LIU_FFMPEG_BASEURL=http://ffmpeg:3000

# --- OpenCode Go 聚合平台（可选）---
LIU_OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1
LIU_OPENCODE_GO_API_KEY=
# LIU_REVERSE_MODEL_VERSION_CALL=01

LIU_SUMMARY_BASE_URL=https://opencode.ai/zen/go/v1
LIU_SUMMARY_API_KEY=
LIU_SUMMARY_MODEL=deepseek-v4-flash

LIU_TRANSLATION_BASE_URL=https://opencode.ai/zen/go/v1
LIU_TRANSLATION_API_KEY=
LIU_TRANSLATION_MODEL=qwen3.6-plus

LIU_IMG2TXT_BASE_URL=https://opencode.ai/zen/go/v1
LIU_IMG2TXT_API_KEY=
LIU_IMG2TXT_MODEL=kimi-k2.6

LIU_SYSTEM2_BASE_URL=https://opencode.ai/zen/go/v1
LIU_SYSTEM2_API_KEY=
LIU_SYSTEM2_MODEL=deepseek-v4-pro
