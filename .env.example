# Liubai Docker 部署环境变量示例
# 复制为 .env 后按需修改

# --- 预构建镜像（默认从 GHCR 拉取）---
# 镜像仓库前缀；可改为自定义镜像站/加速地址以替换 ghcr.io
GHCR_MIRROR=ghcr.io

# 可选：完整镜像地址，设置后将覆盖 GHCR_MIRROR 的默认拼接
# LIUBAI_RUNTIME_IMAGE=ghcr.io/xiaoheicat/liubai-runtime:latest
# LIUBAI_FFMPEG_IMAGE=ghcr.io/xiaoheicat/liubai-ffmpeg:latest
# LIUBAI_WEB_IMAGE=ghcr.io/xiaoheicat/liubai-web:latest

# 本地构建时使用（取消注释并配合 docker-compose.local.yml）：
# COMPOSE_FILE=docker-compose.yml:docker-compose.local.yml

# --- MongoDB（Compose 服务 db）---
MONGODB_DB=liubai

# --- Runtime ---
RUNTIME_PORT=9000
APPID=liubai
LIU_TRIGGER_TOKEN=change-me-in-production

# --- Web（可选，profile with-web）---
WEB_PORT=8080
VITE_API_DOMAIN=http://localhost:9000/

# --- 应用 ---
LIU_APP_NAME=Liubai
LIU_CLOUD_ON=01
LIU_CLOUD_LOGIN=01
# 01=开放登录与注册(默认)  02=关闭登录  03=仅登录不注册
LIU_DOMAIN=https://your-domain.example
# 可选：额外允许 CORS 的前端 Origin（逗号分隔），如本地开发地址
# LIU_CORS_ORIGINS=https://localhost:5173

# 调试密钥（用于 __init__ / debug-* 云函数）
LIU_DEBUG_KEY=

# Web Push 代理（先部署 liubai-push-proxy 到 Cloudflare）
LIU_WEB_PUSH_PROXY_HOST=your-proxy.workers.dev

# OAuth
LIU_GITHUB_OAUTH_CLIENT_ID=
LIU_GITHUB_OAUTH_CLIENT_SECRET=
LIU_GOOGLE_OAUTH_CLIENT_ID=
LIU_GOOGLE_OAUTH_CLIENT_SECRET=

# 邮件
LIU_RESEND_API_KEY=
LIU_RESEND_FROM_EMAIL=

# 支付
LIU_STRIPE_API_KEY=
LIU_STRIPE_ENDPOINT_SECRET=
LIU_STRIPE_TEST_PRICE_ID=

# 七牛（未配置 MinIO 时使用）
LIU_QINIU_ACCESS_KEY=
LIU_QINIU_SECRET_KEY=
LIU_QINIU_BUCKET=
LIU_QINIU_CALLBACK_URL=
LIU_QINIU_CDN_DOMAIN=
LIU_QINIU_CUSTOM_KEY=

# MinIO（Docker 默认捆绑；配置后优先于七牛）
LIU_DOCKER=01
LIU_STORAGE=minio
LIU_MINIO_ENDPOINT=http://minio:9000
# 浏览器上传/读取文件的公网地址（须能从用户浏览器访问）
LIU_MINIO_PUBLIC_URL=http://localhost:19000
LIU_MINIO_ACCESS_KEY=minioadmin
LIU_MINIO_SECRET_KEY=minioadmin
LIU_MINIO_BUCKET=liubai
LIU_MINIO_REGION=us-east-1
# 浏览器跨域上传允许的 Origin（Community Edition 仅支持全局 CORS，逗号分隔；默认 *）
# LIU_MINIO_CORS_ORIGIN=https://liubai.thatlink.top
MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001
# 可选：覆盖 MinIO 镜像
# MINIO_IMAGE=minio/minio:RELEASE.2025-09-07T16-13-09Z
# MINIO_MC_IMAGE=minio/mc:RELEASE.2025-08-13T08-35-41Z

# 设为 01 禁用容器内定时任务
# LIU_DISABLE_CRON=
