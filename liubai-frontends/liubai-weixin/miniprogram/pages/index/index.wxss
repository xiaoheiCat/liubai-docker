/** index.wxss **/

.index-scroll-view {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  width: 100%;
  min-height: 100vh;
}

.index-virtual-one {
  width: 100%;
  height: 25vh;
}

.index-virtual-two {
  width: 100%;
  height: 50px;
}

.index-logo-box {
  margin-bottom: 30px;
  width: 100px;
  height: 100px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.index-logo {
  width: 90%;
  height: 90%;
}

.index-title {
  font-size: var(--head-font);
  color: var(--main-text);
  font-weight: 700;
  margin-bottom: 6px;
  letter-spacing: 1px;
}

.index-desc {
  font-size: var(--desc-font);
  color: var(--main-text);
  margin-bottom: 20vh;
}

.index-btns {
  width: 90%;
  max-width: 400px;
  position: relative;
}

