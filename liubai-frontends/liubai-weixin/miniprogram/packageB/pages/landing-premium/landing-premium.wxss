

.lp-paid-container {
  min-height: 500px;
  height: 90vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.lp-paid-image {
  width: 130px;
  height: 130px;
  margin-top: 40px;
  margin-bottom: 60px;
}

.lp-paid-title {
  font-size: var(--head-font);
  font-weight: 700;
  color: var(--main-text);
  margin-bottom: 10px;
}

.lp-paid-tip {
  font-size: var(--desc-font);
  color: var(--main-text);
  margin-bottom: 60px;
  text-align: center;
  text-wrap: balance;
  width: 90%;
}

.lp-paid-btn {
  width: 50%;
  min-width: 160px;
  max-width: 240px;
  padding-bottom: 20px;
  position: relative;
}



