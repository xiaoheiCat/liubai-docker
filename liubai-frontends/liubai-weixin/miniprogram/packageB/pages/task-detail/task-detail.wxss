@import "../../styles/custom-styles.wxss";

.liu-main-box {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.td-desc {
  width: 100%;
  margin-top: 20px;
  margin-bottom: 30px;
  font-size: var(--big-word-style);
  font-weight: 700;
  color: var(--main-text);
  text-align: center;
  text-wrap: balance;
}

.td-owner {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10px;
  position: relative;
  min-height: 30px;
}

.td-owner-avatar {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 15px;
}

.td-owner-name {
  font-size: var(--title-font);
  color: var(--main-text);
  font-weight: 700;
}


.td-posted-time, .td-from {
  width: 100%;
  margin-bottom: 1px;
  font-size: var(--mini-font);
  color: var(--main-note);
  text-align: center;
  display: inline;
}

.td-virtual-one {
  width: 100%;
  height: 30px;
}