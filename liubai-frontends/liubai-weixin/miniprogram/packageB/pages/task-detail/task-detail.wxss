@import "../../styles/custom-styles.wxss";

.liu-main-box {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.td-desc {
  width: 100%;
  margin-top: 50px;
  margin-bottom: 60px;
  font-size: var(--big-word-style);
  font-weight: 700;
  color: var(--main-text);
  text-align: center;
  text-wrap: balance;
}

.td-owner {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10px;
  position: relative;
  min-height: 30px;
}

.td-owner-avatar {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 15px;
}

.td-owner-name {
  font-size: var(--title-font);
  color: var(--main-text);
  font-weight: 700;
}


.td-posted-time, .td-from {
  width: 100%;
  margin-bottom: 1px;
  font-size: var(--mini-font);
  color: var(--main-note);
  text-align: center;
  display: inline;
}

.td-closed-tag {
  margin-top: 30px;
  padding: 8px 16px;
  border-radius: 8px;
  color: var(--main-note);
  font-size: var(--btn-font);
  font-style: italic;
  position: relative;
  overflow: hidden;
}

.td-closed-tag::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: var(--primary-color);
  opacity: .06;
}

.td-virtual-one {
  width: 100%;
  height: 60px;
}

