<span class="footer-box">

  <block wx:for="{{textList}}" wx:key="id">
    
    <!-- copy text -->
    <span 
      wx:if="{{item.type !== 'plain-text'}}" 
      class="fb-copy {{item.isHover ? 'fb-copy_hovered' : ''}}"
      catchtap="onTapCopy"
      data-text="{{item.text}}"
      data-idx="{{index}}"
      data-type="{{item.type}}"
    >
      <text class="fb-copy-text">{{item.text}}</text>
    </span>

    <!-- other -->
    <text wx:else>{{item.text}}</text>

  </block>

</span>